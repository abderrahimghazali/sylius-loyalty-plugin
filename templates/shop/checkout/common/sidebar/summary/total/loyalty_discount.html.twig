{% import "@SyliusShop/shared/macro/money.html.twig" as money %}

{% set order = hookable_metadata.context.order %}
{% set loyalty_total = order.getAdjustmentsTotal('loyalty_points_discount') %}

{% if loyalty_total %}
    <tr>
        <td>{{ 'loyalty.ui.loyalty_discount'|trans }}:</td>
        <td class="text-end text-success">{{ money.convertAndFormat(loyalty_total) }}</td>
    </tr>
{% endif %}
