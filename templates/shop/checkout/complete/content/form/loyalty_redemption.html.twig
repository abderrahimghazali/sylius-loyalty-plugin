{#
    Checkout loyalty points redemption widget.
    Hooked into: sylius_shop.checkout.complete.content.form
    Context: order (the current cart/order)
#}
{% set order = hookable_metadata.context.order %}
{% set customer = order.customer|default(null) %}
{% if customer is not null %}
    {% set loyalty = loyalty_account(customer) %}
    {% if loyalty is not null and loyalty.balance > 0 %}
        {% set currency_symbol = sylius.channel.baseCurrency.code|sylius_currency_symbol %}
        {% set points_value = loyalty_points_value(loyalty.balance) %}
        {% set ctrl = '@abderrahimghazali/sylius-loyalty-plugin/loyalty-redemption' %}
        <div class="mb-4"
             {{ stimulus_controller(ctrl, {
                 token: order.tokenValue|default(''),
                 balance: loyalty.balance,
                 rate: redemption_rate|default(100),
                 currency: currency_symbol,
             }) }}
        >
            <div class="d-flex align-items-center justify-content-between mb-3">
                <div class="d-flex align-items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: #f59e0b;">
                        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                    </svg>
                    <span style="font-weight: 600; font-size: 1.05rem;">{{ 'loyalty.ui.redeem_points'|trans }}</span>
                </div>
                {% if loyalty.tier is not null %}
                    <span style="display: inline-block; padding: 0.2rem 0.6rem; border-radius: 4px; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.025em;
                        {% if loyalty.tier_color %}background-color: {{ loyalty.tier_color }}; color: white;{% else %}background-color: #e5e7eb; color: #374151;{% endif %}">
                        {{ loyalty.tier }}
                    </span>
                {% endif %}
            </div>

            <div style="background-color: #f8f9fa; border-radius: 8px; padding: 1rem; margin-bottom: 0.75rem;">
                <div class="d-flex align-items-baseline justify-content-between flex-wrap gap-2">
                    <div>
                        <span style="font-size: 1.5rem; font-weight: 700; color: #111827;">{{ loyalty.balance|number_format }}</span>
                        <span style="font-size: 0.875rem; color: #6b7280; margin-left: 0.25rem;">{{ 'loyalty.ui.points'|trans|lower }}</span>
                    </div>
                    <span style="font-size: 0.875rem; color: #6b7280;">
                        {{ 'loyalty.ui.worth'|trans({'%value%': currency_symbol ~ points_value}) }}
                    </span>
                </div>
            </div>

            <div class="d-flex gap-2 align-items-end">
                <div class="flex-grow-1">
                    <label for="loyalty-points-input" style="display: block; font-size: 0.8rem; color: #6b7280; margin-bottom: 0.3rem;">
                        {{ 'loyalty.ui.points_to_redeem'|trans }}
                    </label>
                    <input type="number"
                           id="loyalty-points-input"
                           class="form-control"
                           min="0"
                           max="{{ loyalty.balance }}"
                           placeholder="0"
                           value="{{ order.pointsToRedeem|default(0) > 0 ? order.pointsToRedeem : '' }}"
                           {{ stimulus_target(ctrl, 'input') }}
                           {{ stimulus_action(ctrl, 'onPointsInput', 'input') }}
                           style="border-radius: 6px;"
                    />
                </div>
                <button type="button"
                        class="btn"
                        {{ stimulus_action(ctrl, 'useAll') }}
                        {{ stimulus_target(ctrl, 'redeemAll') }}
                        style="white-space: nowrap; border: 1px solid #d1d5db; border-radius: 6px; padding: 0.47rem 1rem; font-size: 0.875rem; color: #374151; background: white;">
                    {{ 'loyalty.ui.use_all'|trans }}
                </button>
                <button type="button"
                        class="btn"
                        {{ stimulus_action(ctrl, 'clear') }}
                        style="white-space: nowrap; border: 1px solid #d1d5db; border-radius: 6px; padding: 0.47rem 1rem; font-size: 0.875rem; color: #6b7280; background: white;">
                    {{ 'loyalty.ui.clear'|trans }}
                </button>
            </div>

            <div class="text-danger mt-1 d-none"
                 style="font-size: 0.8rem;"
                 {{ stimulus_target(ctrl, 'error') }}></div>

            <div class="d-none mt-3 pt-2"
                 style="border-top: 1px dashed #e5e7eb;"
                 {{ stimulus_target(ctrl, 'discount') }}>
            </div>
        </div>
    {% endif %}
{% endif %}
