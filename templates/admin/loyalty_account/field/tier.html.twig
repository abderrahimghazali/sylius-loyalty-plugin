{% if data is not null %}
    <span class="badge" {% if data.color %}style="background-color: {{ data.color|e('html_attr') }}; color: white;"{% endif %}>
        {{ data.name }}
    </span>
{% else %}
    <span class="badge bg-secondary text-white">{{ 'loyalty.ui.no_tier'|trans }}</span>
{% endif %}
