{% set conflicts = loyalty_earning_rule_conflicts(data) %}

{% if conflicts|length > 0 %}
    <span class="badge bg-warning text-dark" title="{% for c in conflicts %}Overlaps with &quot;{{ c.rule.name }}&quot; on: {{ c.overlap|join(', ') }}&#10;{% endfor %}">
        {{ ux_icon('tabler:alert-triangle', {class: 'icon icon-sm'}) }}
        {{ conflicts|length }} {{ conflicts|length == 1 ? 'conflict' : 'conflicts' }}
    </span>
{% else %}
    <span class="text-success">
        {{ ux_icon('tabler:check', {class: 'icon icon-sm'}) }}
    </span>
{% endif %}
