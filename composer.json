{
    "name": "abderrahimghazali/sylius-loyalty-plugin",
    "type": "sylius-plugin",
    "description": "Points-based loyalty and rewards system for Sylius 2.x",
    "license": "MIT",
    "keywords": ["sylius", "sylius-plugin", "loyalty", "rewards", "points", "ecommerce"],
    "homepage": "https://github.com/abderrahimghazali/sylius-loyalty-plugin",
    "authors": [
        {
            "name": "Abderrahim Ghazali",
            "homepage": "https://github.com/abderrahimghazali"
        }
    ],
    "support": {
        "issues": "https://github.com/abderrahimghazali/sylius-loyalty-plugin/issues",
        "source": "https://github.com/abderrahimghazali/sylius-loyalty-plugin"
    },
    "require": {
        "php": "^8.2",
        "doctrine/orm": "^2.17 || ^3.0",
        "sylius/sylius": "^2.1",
        "symfony/framework-bundle": "^7.0",
        "symfony/stimulus-bundle": "^2.0",
        "symfony/ux-live-component": "^2.0",
        "symfony/ux-twig-component": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "Abderrahim\\SyliusLoyaltyPlugin\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\Abderrahim\\SyliusLoyaltyPlugin\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "branch-alias": {
            "dev-main": "2.0-dev"
        },
        "sylius-plugin-name": "Loyalty Plugin"
    },
    "config": {
        "sort-packages": true
    }
}
