<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                  https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <mapped-superclass name="Abderrahim\SyliusLoyaltyPlugin\Entity\LoyaltyAccount"
                       table="loyalty_account">

        <id name="id" column="id" type="integer">
            <generator strategy="AUTO"/>
        </id>

        <field name="pointsBalance" column="points_balance" type="integer" nullable="false">
            <options>
                <option name="default">0</option>
            </options>
        </field>

        <field name="lifetimePoints" column="lifetime_points" type="integer" nullable="false">
            <options>
                <option name="default">0</option>
            </options>
        </field>

        <field name="enabled" column="enabled" type="boolean" nullable="false">
            <options>
                <option name="default">1</option>
            </options>
        </field>

        <field name="createdAt" column="created_at" type="datetime" nullable="false"/>
        <field name="updatedAt" column="updated_at" type="datetime" nullable="true"/>

        <many-to-one field="customer"
                     target-entity="Sylius\Component\Customer\Model\CustomerInterface">
            <join-column name="customer_id" referenced-column-name="id" nullable="false" unique="true"/>
        </many-to-one>

        <many-to-one field="tier"
                     target-entity="Abderrahim\SyliusLoyaltyPlugin\Entity\LoyaltyTierInterface">
            <join-column name="tier_id" referenced-column-name="id" nullable="true"/>
        </many-to-one>

        <one-to-many field="transactions"
                     target-entity="Abderrahim\SyliusLoyaltyPlugin\Entity\PointTransactionInterface"
                     mapped-by="loyaltyAccount">
            <cascade>
                <cascade-persist/>
            </cascade>
            <order-by>
                <order-by-field name="createdAt" direction="DESC"/>
            </order-by>
        </one-to-many>

    </mapped-superclass>

</doctrine-mapping>
