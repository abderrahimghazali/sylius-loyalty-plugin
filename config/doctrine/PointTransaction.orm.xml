<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                  https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <mapped-superclass name="Abderrahim\SyliusLoyaltyPlugin\Entity\PointTransaction"
                       table="loyalty_point_transaction">

        <id name="id" column="id" type="integer">
            <generator strategy="AUTO"/>
        </id>

        <field name="type" column="type" type="string" length="20" nullable="false" enumType="Abderrahim\SyliusLoyaltyPlugin\Enum\TransactionType"/>

        <field name="points" column="points" type="integer" nullable="false"/>

        <field name="description" column="description" type="string" length="255" nullable="true"/>

        <field name="expiresAt" column="expires_at" type="datetime" nullable="true"/>

        <field name="expired" column="expired" type="boolean" nullable="false">
            <options>
                <option name="default">0</option>
            </options>
        </field>

        <field name="createdAt" column="created_at" type="datetime" nullable="false"/>

        <many-to-one field="loyaltyAccount"
                     target-entity="Abderrahim\SyliusLoyaltyPlugin\Entity\LoyaltyAccountInterface"
                     inversed-by="transactions">
            <join-column name="loyalty_account_id" referenced-column-name="id" nullable="false"/>
        </many-to-one>

        <many-to-one field="order"
                     target-entity="Sylius\Component\Core\Model\OrderInterface">
            <join-column name="order_id" referenced-column-name="id" nullable="true"/>
        </many-to-one>

    </mapped-superclass>

</doctrine-mapping>
