<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                  https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <entity name="Abderrahim\SyliusLoyaltyPlugin\Entity\LoyaltyEarningRuleChannelConfiguration"
            table="loyalty_earning_rule_channel_configuration">

        <unique-constraints>
            <unique-constraint name="uniq_lercc_rule_channel" columns="earning_rule_id,channel_id"/>
        </unique-constraints>

        <id name="id" column="id" type="integer">
            <generator strategy="AUTO"/>
        </id>

        <field name="pointsPerProduct" column="points_per_product" type="integer" nullable="false">
            <options>
                <option name="default">1</option>
            </options>
        </field>

        <many-to-one field="earningRule"
                     target-entity="Abderrahim\SyliusLoyaltyPlugin\Entity\LoyaltyEarningRuleInterface"
                     inversed-by="channelConfigurations">
            <join-column name="earning_rule_id" referenced-column-name="id" nullable="false" on-delete="CASCADE"/>
        </many-to-one>

        <many-to-one field="channel"
                     target-entity="Sylius\Component\Channel\Model\ChannelInterface">
            <join-column name="channel_id" referenced-column-name="id" nullable="false"/>
        </many-to-one>

    </entity>

</doctrine-mapping>
