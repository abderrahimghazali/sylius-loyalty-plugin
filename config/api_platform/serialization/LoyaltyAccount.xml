<?xml version="1.0" encoding="UTF-8" ?>
<serializer xmlns="http://symfony.com/schema/dic/serializer-mapping"
            xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
            xsi:schemaLocation="http://symfony.com/schema/dic/serializer-mapping
            https://symfony.com/schema/dic/serializer-mapping/serializer-mapping-1.0.xsd">

    <class name="Abderrahim\SyliusLoyaltyPlugin\Entity\LoyaltyAccount">
        <attribute name="id">
            <group>loyalty:admin:account:index</group>
            <group>loyalty:admin:account:show</group>
            <group>loyalty:shop:account:show</group>
        </attribute>

        <attribute name="pointsBalance">
            <group>loyalty:admin:account:index</group>
            <group>loyalty:admin:account:show</group>
            <group>loyalty:shop:account:show</group>
        </attribute>

        <attribute name="lifetimePoints">
            <group>loyalty:admin:account:index</group>
            <group>loyalty:admin:account:show</group>
            <group>loyalty:shop:account:show</group>
        </attribute>

        <attribute name="enabled">
            <group>loyalty:admin:account:index</group>
            <group>loyalty:admin:account:show</group>
            <group>loyalty:admin:account:update</group>
        </attribute>

        <attribute name="tier">
            <group>loyalty:admin:account:show</group>
            <group>loyalty:shop:account:show</group>
        </attribute>

        <attribute name="createdAt">
            <group>loyalty:admin:account:show</group>
        </attribute>
    </class>

</serializer>
